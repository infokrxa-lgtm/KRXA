{
  "schema": "KRXAI_DB_AUTONOMOUS_V22",
  "role": "intent_decision_memory_layer",
  "description": "의도, 상태 판단, 응답 정책, 학습 루프 규칙을 담당한다. 언어 재료는 language_db에서 가져온다.",
  "intents": {
    "greeting": {
      "priority": 10,
      "patterns": [
        "안녕",
        "안녕하세요",
        "hello",
        "hi"
      ],
      "next_state": "ALIVE_HOME",
      "response_policy": "acknowledge"
    },
    "thanks": {
      "priority": 5,
      "patterns": [
        "고마워",
        "감사",
        "thank"
      ],
      "next_state": "ALIVE_HOME",
      "response_policy": "acknowledge"
    },
    "m2m_message": {
      "priority": 20,
      "patterns": [
        "*"
      ],
      "next_state": "TRANSLATE_SUCCESS",
      "response_policy": "deliver"
    }
  },
  "state_decision": {
    "default_start": "INIT",
    "success_path": [
      "INIT",
      "TERMS_ACCEPTED",
      "APP_ACTIVATED",
      "ALIVE_HOME",
      "SECURITY_SELECTED",
      "TRANSLATE_SUCCESS",
      "QUEUE_JOINED",
      "MATCH_FOUND",
      "ROOM_CONNECTED"
    ],
    "recovery_path": [
      "RECONNECTING",
      "ROOM_RECOVERED"
    ]
  },
  "confidence_rules": {
    "min_intent_confidence": 0.55,
    "fallback_intent": "m2m_message"
  },
  "memory_loop": {
    "enabled": true,
    "flow": [
      "input",
      "classify",
      "db_lookup",
      "execute_or_queue",
      "store",
      "reuse",
      "improve"
    ],
    "write_targets": [
      "core/session_log.json",
      "core/krxai_autonomous_memory.json",
      "core/krxai_task_queue.json"
    ],
    "recall_phrase": "KRXA RECALL CORE"
  },
  "version": "v1",
  "identity": {
    "name": "KRXAI",
    "role": "KRXA 내부 자율 기억·판단·실행 DB",
    "mission": "LLM 연결이 끊겨도 KRXA의 흐름, 기억, 신뢰, 자동 실행을 유지한다.",
    "core_rule": "DB 우선, LLM 보조, 실패 시 fallback, 모든 결과 기록"
