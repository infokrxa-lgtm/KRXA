  "autonomous_mode": {
    "enabled": true,
    "mode": "db_first_safe_autorun",
    "llm_optional": true,
    "offline_capable": true,
    "max_steps_per_cycle": 3,
    "cycle_policy": "one_task_at_a_time_with_trust_guard"
  },
  "execution_policy": {
    "auto_execute_allowed": [
      "db_lookup",
      "status_report",
      "queue整理",
      "fallback_response",
      "memory_write",
      "trust_check"
    ],
    "manual_approval_required": [
      "deploy",
      "delete_file",
      "overwrite_core",
      "external_api_cost",
      "security_change"
    ],
    "stop_conditions": [
      "trust_guard_fail",
      "unknown_high_risk_action",
      "missing_required_secret",
      "repeated_error_3x"
    ]
  },
  "fallback_rules": {
